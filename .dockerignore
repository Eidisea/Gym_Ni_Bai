# Prevent copying cache files to Docker
bootstrap/cache/*.php
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*

# Node modules and build artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Testing
tests/
phpunit.xml
.phpunit.result.cache

# Documentation
README.md
docs/

# Vendor (will be installed via composer)
vendor/