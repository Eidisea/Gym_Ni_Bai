/vendor/
/node_modules/
/.git/

# CRITICAL: Do not copy local environments to Render!
.env
.env.local
.env.production
.env.backup
# But allow .env.example for Docker build
!.env.example

# Ignore locally compiled assets and caches
/public/build/
/bootstrap/cache/*.php
/database/*.sqlite
/storage/app/public/*
!/storage/app/public/.gitignore